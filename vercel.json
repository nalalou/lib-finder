{
  "rewrites": [
    { "source": "/api/submit", "destination": "/api/submit" },
    { "source": "/v1/library-requests/resolve", "destination": "/api/resolve" }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
